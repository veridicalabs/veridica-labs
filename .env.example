# Backend
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/veridica?schema=public"

# AI Provider (OpenClaw - plug in later)
AI_PROVIDER_API_KEY="mock-key"
AI_PROVIDER_BASE_URL="https://api.openclaw.example.com"

# ── Blockchain (Syscoin NEVM) ──────────────────────────────────────────────────

# Syscoin NEVM Mainnet (chainId: 57)
RPC_URL="https://rpc.syscoin.org"

# Syscoin NEVM Testnet — Tanenbaum (chainId: 5700)
RPC_URL_TESTNET="https://rpc.tanenbaum.io"

# Deployer hot wallet private key (0x-prefixed, no quotes in actual .env)
DEPLOYER_PRIVATE_KEY=""

# Backend oracle wallet — calls registerConversion() on-chain
# If empty, deploy script defaults to deployer address
VERIFIER_ADDRESS=""

# Platform fee recipient wallet
# If empty, deploy script defaults to deployer address
TREASURY_ADDRESS=""

# Platform fee in basis points (200 = 2%). Max 1000 (10%)
PLATFORM_FEE_BPS="200"

# Populated after deploy (run: npm run deploy:syscoinTestnet --workspace=contracts)
ESCROW_CONTRACT_ADDRESS=""

# Syscoin block explorer API key (optional, for contract verification)
SYSCOIN_EXPLORER_API_KEY=""

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_CHAIN_ID="5700"
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=""
