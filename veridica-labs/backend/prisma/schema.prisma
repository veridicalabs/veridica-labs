generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id                String       @id @default(cuid())
  name              String
  description       String
  budget            Float
  costPerConversion Float
  deposited         Float        @default(0)
  spent             Float        @default(0)
  status            String       @default("ACTIVE") // ACTIVE | PAUSED | COMPLETED
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  leads             Lead[]
  conversions       Conversion[]
  conversations     Conversation[]
}

model Lead {
  id            String         @id @default(cuid())
  campaignId    String
  name          String
  email         String
  createdAt     DateTime       @default(now())

  campaign      Campaign       @relation(fields: [campaignId], references: [id])
  conversations Conversation[]
  conversions   Conversion[]
}

model Conversation {
  id         String   @id @default(cuid())
  campaignId String
  leadId     String
  messages   Json     @default("[]") // Array of { role, content }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  lead       Lead     @relation(fields: [leadId], references: [id])
}

model Conversion {
  id         String   @id @default(cuid())
  campaignId String
  leadId     String
  amount     Float
  status     String   @default("CONFIRMED") // CONFIRMED | PAID
  createdAt  DateTime @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  lead       Lead     @relation(fields: [leadId], references: [id])
}

model AIUsageLog {
  id           String   @id @default(cuid())
  campaignId   String?
  action       String   // GENERATE_AD | RESPOND_LEAD | CONFIRM_CONVERSION
  model        String   @default("gpt-4o")
  promptTokens Int      @default(0)
  outputTokens Int      @default(0)
  latencyMs    Int      @default(0)
  success      Boolean  @default(true)
  error        String?
  createdAt    DateTime @default(now())
}

model SystemEvent {
  id        String   @id @default(cuid())
  type      String   // API_REQUEST | ERROR | ESCROW_DEPOSIT | ESCROW_RELEASE | AGENT_CALL
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
}
